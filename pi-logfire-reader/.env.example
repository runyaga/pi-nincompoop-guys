# Copy to .env (gitignored) or export these in your shell before running pi.

# Logfire read token. Needs project:read + project:read_otlp scopes.
# Must be a v2 token (prefix contains _v2_). v1 tokens (pylf_v1_...) do NOT work.
LOGFIRE_READ_TOKEN=pylf_v2_xx_your_read_token_here

# Optional: override the MCP endpoint. Defaults to the US region.
#   US: https://logfire-us.pydantic.dev/mcp
#   EU: https://logfire-eu.pydantic.dev/mcp
# LOGFIRE_MCP_URL=https://logfire-us.pydantic.dev/mcp
