# Copy to .env (gitignored) or export these in your shell before running pi.

# Logfire read token (project:read scope). Get one from your Logfire project settings.
LOGFIRE_READ_TOKEN=pylf_v1_xx_your_read_token_here

# Optional: override the MCP endpoint. Defaults to the EU region.
#   EU: https://logfire-eu.pydantic.dev/mcp
#   US: https://logfire-us.pydantic.dev/mcp
# LOGFIRE_MCP_URL=https://logfire-eu.pydantic.dev/mcp
