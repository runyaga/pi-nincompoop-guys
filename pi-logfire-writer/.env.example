# Copy to .env (gitignored) or export these before running pi.

# Logfire WRITE token (project:write scope) — used to push traces to Logfire.
# Never commit a real token.
LOGFIRE_WRITE_TOKEN=pylf_v2_xx_your_write_token_here

# Optional: region. Defaults to the token's region (pylf_v2_us_... -> us), else "us".
# LOGFIRE_REGION=us

# Optional: override the OTLP endpoint for a self-hosted Logfire instance.
# Accepts a base URL (the /v1/traces path and an explicit port are added for you).
# LOGFIRE_WRITER_ENDPOINT=https://logfire.my-company.com

# Optional: start configured-but-paused (toggle at runtime with /logfire-pause
# and /logfire-resume). Default is unpaused.
# PI_LOGFIRE_WRITER_START_PAUSED=1

# Optional: hard-disable export without removing the extension.
# PI_LOGFIRE_WRITER_DISABLED=1

# Optional pi-otel passthrough knobs (see pi-otel docs):
#   PI_OTEL_CAPTURE_CONTENT=metadata_only|no_tool_content|full
#   OTEL_SERVICE_NAME=pi
